{
  "name": "@rqbbox/experience",
  "version": "1.0.0",
  "description": "RQBBOX Experience — Next-generation digital platform combining gaming, AI, productivity, media, and cloud services into one unified RhysTech experience.",
  "private": false,
  "main": "electron-main.js",
  "bin": {
    "rqbbox-experience": "rqbbox-launcher.js"
  },
  "scripts": {
    "start": "electron .",
    "dev": "node server.js --dev",
    "server": "node server.js",
    "build:full": "electron-builder --win --config --config electron-builder-full.yml",
    "build:lite": "electron-builder --win --config --config electron-builder-lite.yml",
    "build:portable": "electron-builder --win --config --config electron-builder-portable.yml",
    "build:all": "npm run build:full && npm run build:lite && npm run build:portable"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtech-rqbbox-os/RQBBOX-Experience.git"
  },
  "keywords": [
    "gaming",
    "ai",
    "productivity",
    "media",
    "cloud",
    "rqbbox",
    "rhystech",
    "experience",
    "dashboard",
    "portable",
    "usb",
    "windows"
  ],
  "author": "RhysTech",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rtech-rqbbox-os/RQBBOX-Experience/issues"
  },
  "homepage": "https://rhystech.io/rqbbox-experience",
  "build": {
    "appId": "com.rhystech.rqbbox.experience",
    "productName": "RQBBOX Experience",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!windows/scripts",
      "!node_modules/electron",
      "!node_modules/electron-builder",
      "!node_modules/pkg",
      "!node_modules/nexe",
      "!*.bat",
      "!*.cmd"
    ],
    "extraMetadata": {
      "main": "electron-main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "RQBBOX-Experience-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "compression": "store",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RQBBOX Experience OS 1.0"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
